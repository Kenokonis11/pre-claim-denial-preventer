# ===========================================
# Pre-Claim Denial Preventer - Environment
# ===========================================

# --- Option A: Google Gemini (recommended if you have a Gemini API key) ---
GOOGLE_API_KEY=your_key_here
LLM_MODEL_NAME=gemini-2.0-flash

# --- Option B: OpenAI-compatible endpoint (Together AI, Fireworks, Ollama) ---
# Uncomment these and comment out GOOGLE_API_KEY above to use instead:
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Embedding Model (local HuggingFace, no API key needed)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
